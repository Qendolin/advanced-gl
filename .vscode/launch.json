	"version": "0.2.0",
	"configurations": [
		{
			"name": "Project 01",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/Project01",
			"output": "__debug_bin.exe"
		},
		{
			"name": "Project 02",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/Project02",
			"output": "__debug_bin.exe"
		},
		{
			"name": "Project 03",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/Project03",
			"output": "__debug_bin.exe"
		},
		{
			"name": "iblconv",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/Project03/cmd/iblconv",
			"args": ["specular", "-samples", "1048576", "studio_small.iblenv"]
		},
		{
			"name": "brdflut",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/Project03/cmd/brdflut",
			"args": ["-compression", "1", "ibl_brdf_lut.f32"]
		},
		{
			"name": "Normals Issue",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/Project03/examples/normals_issue",
			"output": "__debug_bin.exe",
			"cwd": "${workspaceFolder}/Project03",
			"args": []
		}
	]
}
